<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>

	<appSettings>
		<add key="P_threshold"   value="5.0" />
		<add key="CO_threshold"  value="50.0" />
		<add key="NO2_threshold" value="20.0" />
		<add key="OutputFolder"  value="C:\SensorData" />
	</appSettings>

	<system.serviceModel>
		<services>
			<service name="Service.SensorService"
					 behaviorConfiguration="SensorServiceBehavior">
				<endpoint address=""
						  binding="netTcpBinding"
						  bindingConfiguration="SensorTcpBinding"
						  contract="Common.ISensorService" />
				<endpoint address="mex"
						  binding="mexTcpBinding"
						  contract="IMetadataExchange" />
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:9000/SensorService" />
					</baseAddresses>
				</host>
			</service>
		</services>

		<bindings>
			<netTcpBinding>
				<binding name="SensorTcpBinding"
						 maxReceivedMessageSize="10485760"
						 receiveTimeout="00:10:00"
						 sendTimeout="00:10:00" />
			</netTcpBinding>
		</bindings>

		<behaviors>
			<serviceBehaviors>
				<behavior name="SensorServiceBehavior">
					<serviceMetadata />
					<serviceDebug includeExceptionDetailInFaults="true" />
				</behavior>
			</serviceBehaviors>
		</behaviors>
	</system.serviceModel>
	
	
	
	
</configuration>